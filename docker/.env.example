# CityPulse Environment Variables
# These are the defaults for local development.
# In Docker, these are overridden by docker-compose.yml

SPRING_R2DBC_URL=r2dbc:postgresql://localhost:5432/citypulse
SPRING_R2DBC_USERNAME=citypulse
SPRING_R2DBC_PASSWORD=citypulse123
JWT_SECRET=CityPulseSecretKey2026ForJWTTokenGenerationMustBe256BitsLong!
JWT_EXPIRATION=3600000
JWT_REFRESH_EXPIRATION=86400000
